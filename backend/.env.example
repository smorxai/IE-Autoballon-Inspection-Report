# Copy to backend/.env and fill in values. Never commit .env.

# ── AI / vision (Anthropic Claude — mechanical engineer ballooning prompts) ─
ANTHROPIC_API_KEY=sk-ant-your-key-here
BALLOON_VISION_MODEL=claude-sonnet-4-6
# BALLOON_VISION_PROVIDER=anthropic   # anthropic | openai
# BALLOON_CROP_MAX_TOKENS=800           # per-detection extraction
# BALLOON_FULL_DRAWING_ANALYSIS=1       # full balloon table + CTQ summaries (slower)
# BALLOON_FULL_ANALYSIS_MAX_TOKENS=12000
# OPENAI_API_KEY=sk-your-key-here       # optional fallback
# GROQ_API_KEY=
# GEMINI_API_KEY=

# ── Auth database (login / orgs / engineers) ────────────────────────────────
# Production: Neon/PostgreSQL URL. Local dev: leave unset OR use AUTH_USE_SQLITE=1
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
# AUTH_USE_SQLITE=1                    # force local backend/.data/auth.sqlite
# BALLOON_AUTH_FALLBACK_SQLITE=1       # if Postgres unreachable, use SQLite (default on)

# ── JWT & super admin (seeded on first startup) ─────────────────────────────
JWT_SECRET_KEY=change-me-to-a-long-random-secret
SUPER_ADMIN_EMAIL=admin@smorx.ai
SUPER_ADMIN_PASSWORD=YourSecurePassword123!
# BALLOON_RESET_SUPER_ADMIN_PASSWORD=1   # Render only: redeploy once to apply SUPER_ADMIN_PASSWORD, then remove

# ── Trial & payment ─────────────────────────────────────────────────────────
TRIAL_DAYS=7
RAZORPAY_KEY_ID=rzp_test_xxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_AMOUNT_PAISE=99900

# ── Detection (optional) ───────────────────────────────────────────────────
# BALLOON_PLACEMENT=legacy            # legacy=AutoBallooning grid (default) | tight=beside box
# BALLOON_DIMENSION_BBOX_REFINE=1     # expand vertical/horizontal dim boxes (default on)
# BALLOON_LLM_INCLUDE_META=0          # do not add guessed view/inspection text to table
# BALLOON_YOLO_CONF=0.06              # base YOLO conf (raster)
# BALLOON_YOLO_CONF_PDF=0.20          # PDF uploads
# BALLOON_YOLO_CONF_DIMENSIONS=0.07
# BALLOON_STRICT_DETECTION_FILTER=1   # aggressive ink/border filter (default: light)
# BALLOON_VISION_FALLBACK=together     # Stage1 YOLO balloons, Stage2 Claude grid gap-fill (default)
# BALLOON_VISION_GRID_COLS=8           # Claude scans drawing grid-wise (match sheet grid)
# BALLOON_VISION_GRID_ROWS=6
# BALLOON_VISION_MERGE_IOU=0.40        # skip Claude box if overlaps existing YOLO balloon region
# BALLOON_VISION_MIN_CONF=0.62         # reject low-confidence Claude boxes (anti-hallucination)
# BALLOON_VISION_MODEL=claude-sonnet-4-6
# BALLOON_VISION_MERGE_IOU=0.42        # overlap with YOLO before adding Claude box
# BALLOON_POST_DETECT_CLEANUP=1        # remove line/blank false positives after merge
# BALLOON_YOLO_DEDUPE_IOU=0.72         # dedupe within YOLO only (keeps all distinct dims)
# BALLOON_DEDUPE_IOU=0.50              # legacy; cleanup no longer collapses all YOLO boxes
# BALLOON_VISION_FALLBACK_MIN_YOLO=8   # lazy mode only
# BALLOON_VISION_FALLBACK_MIN_DIMS=18  # lazy mode only
# BALLOON_VISION_MAX_SIDE=2048
# BALLOON_VISION_MAX_TOKENS=8192
# BALLOON_REGION_PREPASS=1          # Claude segments views before gap-fill (default on)
# BALLOON_REGION_MAX_TOKENS=4096
# BALLOON_OPENCV_DIM_LINES=1        # Hough extension-line candidates (default on)
# BALLOON_OPENCV_AUTO_MERGE=1       # merge non-overlapping OpenCV boxes into detections
# BALLOON_OPENCV_MERGE_IOU=0.42
# BALLOON_OPENCV_MAX_CANDIDATES=80
# BALLOON_OCR_ENGINE=claude         # claude vision OCR per crop (default if API key) | tesseract
# BALLOON_OCR_TESSERACT_FALLBACK=1  # rotate/upscale + Tesseract when Claude misses vertical dims
# BALLOON_OCR_TRY_ALL_ROTATIONS=1   # try 0/90/180/270° on each crop (vertical 12, 38, etc.)

# ── Render.com (avoid HTTP 502 on auto ballooning) ───────────────────────────
# Auto-on when RENDER=true. YOLO + limited crop OCR only (no slow Claude grid passes).
# BALLOON_RENDER_SAFE=1
# BALLOON_MAX_CROP_OCR=30
# BALLOON_VISION_FALLBACK=never
# BALLOON_REGION_PREPASS=0
# BALLOON_COVERAGE_VERIFY=0
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# ── Dev only: skip login on API and /app ────────────────────────────────────
# SMORX_DISABLE_BALLOON_AUTH=1

# ── Server ──────────────────────────────────────────────────────────────────
# BALLOON_UI_PORT=9080
# BALLOON_USE_BUNDLED_UI=1
